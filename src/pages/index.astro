---
import { getCollection } from 'astro:content';
import PostRow from '../components/PostRow.astro';
import Rule from '../components/Rule.astro';
import Tag from '../components/Tag.astro';
import SiteLayout from '../layouts/SiteLayout.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
import { getAllTags, getPublishedWriting, getTagHref } from '../utils/writing';

const posts = getPublishedWriting(await getCollection('writing'));
const tags = getAllTags(posts);
---

<SiteLayout title={SITE_TITLE} description={SITE_DESCRIPTION} active="writing" promptPath="">
	<section class="page-shell hero" aria-labelledby="site-heading">
		<p class="ds-overline">$ ./blog --list --recent</p>
		<h1 id="site-heading">
			Notes from inside the <span>blast radius</span>.
		</h1>
		<p class="lede">
			Ramblings from a dude who'd rather drink beer with his pigs than build software.
		</p>
	</section>

	<section class="page-shell index-grid" aria-labelledby="writing-heading">
		<div class="writing-list">
			<Rule label={`${posts.length} ${posts.length === 1 ? 'entry' : 'entries'}`} />
			<h2 id="writing-heading" class="visually-hidden">Writing</h2>
			{
				posts.length > 0 ? (
					posts.map((post, index) => <PostRow post={post} index={index} />)
				) : (
					<div class="empty-state">
						<p>No public articles yet.</p>
					</div>
				)
			}
		</div>

		<aside class="topic-rail" aria-labelledby="topics-heading">
			<h2 id="topics-heading" class="ds-overline">// topics</h2>
			{
				tags.length > 0 ? (
					<div class="tags">
						{tags.map((tag) => (
							<Tag href={getTagHref(tag.name)} count={tag.count}>
								{tag.name}
							</Tag>
						))}
					</div>
				) : (
					<p>No tags yet.</p>
				)
			}
		</aside>
	</section>
</SiteLayout>

<style>
	.hero {
		padding-bottom: var(--space-4);
	}

	.hero .ds-overline {
		margin: 0 0 var(--space-4);
	}

	h1 {
		color: var(--text);
		font-family: var(--font-display);
		font-size: var(--text-display);
		font-weight: var(--weight-bold);
		letter-spacing: var(--tracking-tight);
		line-height: var(--leading-tight);
		margin: 0;
		max-width: 780px;
		overflow-wrap: anywhere;
	}

	h1 span {
		color: var(--accent);
	}

	.lede {
		color: var(--text-secondary);
		font-size: var(--text-body-lg);
		line-height: var(--leading-relaxed);
		margin: var(--space-5) 0 0;
		max-width: 560px;
	}

	.index-grid {
		align-items: start;
		display: grid;
		gap: var(--space-8);
		grid-template-columns: minmax(0, 1fr) 280px;
		padding-top: var(--space-4);
	}

	.writing-list {
		min-width: 0;
	}

	.empty-state {
		border-bottom: 1px solid var(--border);
		color: var(--text-secondary);
		padding: var(--space-6) 0;
	}

	.topic-rail {
		border: 1px solid var(--border);
		border-left: 2px solid var(--accent);
		border-radius: var(--radius-sm);
		padding: var(--space-5);
		position: sticky;
		top: 96px;
	}

	.topic-rail h2 {
		margin: 0 0 var(--space-4);
	}

	.topic-rail p {
		color: var(--text-muted);
		margin: 0;
	}

	.tags {
		display: flex;
		flex-wrap: wrap;
		gap: var(--space-2);
	}

	@media (max-width: 840px) {
		.index-grid {
			grid-template-columns: 1fr;
		}

		.topic-rail {
			position: static;
		}
	}
</style>
