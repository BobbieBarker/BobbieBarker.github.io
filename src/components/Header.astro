---
import TerminalMark from './TerminalMark.astro';
import ThemeToggle from './ThemeToggle.astro';

interface Props {
	active?: 'writing' | 'tags' | 'about';
	promptPath?: string;
}

const { active = 'writing', promptPath = '' } = Astro.props;
const navItems = [
	{ id: 'writing', label: 'writing', href: '/' },
	{ id: 'tags', label: 'tags', href: '/tags/' },
	{ id: 'about', label: 'about', href: '/about/' },
] as const;
---

<header class="site-header">
	<div class="header-inner">
		<a class="prompt" href="/" aria-label="Home">
			<TerminalMark />
			<span class="prompt-text">
				<span class="accent">~</span><span class="path">/{promptPath}</span><span class="cursor" aria-hidden="true">_</span>
			</span>
		</a>
		<nav aria-label="Primary navigation">
			{
				navItems.map((item) => (
					<a href={item.href} aria-current={active === item.id ? 'page' : undefined}>
						{item.label}
					</a>
				))
			}
			<ThemeToggle />
		</nav>
	</div>
</header>

<style>
	.site-header {
		background: color-mix(in srgb, var(--bg) 88%, transparent);
		backdrop-filter: blur(10px);
		border-bottom: 2px solid var(--border-strong);
		position: sticky;
		top: 0;
		z-index: 20;
	}

	.header-inner {
		align-items: center;
		display: flex;
		gap: var(--space-4);
		justify-content: space-between;
		margin: 0 auto;
		max-width: var(--container-wide);
		padding: var(--space-4) var(--gutter);
	}

	.prompt {
		align-items: center;
		color: var(--text-secondary);
		display: inline-flex;
		font-family: var(--font-mono);
		font-size: var(--text-body);
		font-weight: var(--weight-medium);
		gap: var(--space-3);
		min-height: 34px;
		text-decoration: none;
	}

	.prompt:hover {
		color: var(--text);
		text-decoration: none;
	}

	.prompt-text {
		align-items: baseline;
		display: inline-flex;
		line-height: 1;
	}

	.accent,
	.cursor {
		color: var(--accent);
	}

	.cursor {
		animation: blink 1.1s steps(1) infinite;
		margin-left: 2px;
	}

	nav {
		align-items: center;
		display: flex;
		flex-wrap: wrap;
		gap: var(--space-5);
		justify-content: flex-end;
	}

	nav > a {
		color: var(--text-secondary);
		font-family: var(--font-mono);
		font-size: var(--text-sm);
		font-weight: var(--weight-medium);
		letter-spacing: var(--tracking-wide);
		min-height: 34px;
		text-decoration: none;
		text-transform: uppercase;
	}

	nav > a[aria-current='page'],
	nav > a:hover,
	nav > a:focus-visible {
		color: var(--accent);
		text-decoration: underline;
	}

	@media (max-width: 680px) {
		.header-inner {
			align-items: flex-start;
			flex-direction: column;
			padding-inline: var(--space-4);
		}

		nav {
			gap: var(--space-3);
			justify-content: flex-start;
			width: 100%;
		}
	}
</style>
