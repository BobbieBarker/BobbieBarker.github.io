---
import Tag from './Tag.astro';
import type { WritingPost } from '../utils/writing';
import { formatDate, getPostNumber, getReadingTime, getTagHref } from '../utils/writing';

interface Props {
	post: WritingPost;
	index: number;
}

const { post, index } = Astro.props;
---

<article class="post-row">
	<div class="post-number" aria-hidden="true">{getPostNumber(index)}</div>
	<div class="post-copy">
		<div class="ds-overline">{formatDate(post.data.date)} - {getReadingTime(post)}</div>
		<h2><a href={`/writing/${post.id}/`}>{post.data.title}</a></h2>
		<p>{post.data.excerpt}</p>
		<div class="post-tags" aria-label="Tags">
			{post.data.series && <span class="series">{post.data.series}</span>}
			{post.data.tags.map((tag) => <Tag href={getTagHref(tag)} size="sm">{tag}</Tag>)}
		</div>
	</div>
</article>

<style>
	.post-row {
		border-bottom: 1px solid var(--border);
		display: grid;
		gap: var(--space-5);
		grid-template-columns: 48px minmax(0, 1fr);
		padding: var(--space-5) 0;
	}

	.post-number {
		color: var(--accent);
		font-family: var(--font-display);
		font-size: var(--text-h3);
		font-weight: var(--weight-bold);
		line-height: 1;
	}

	.post-copy {
		min-width: 0;
	}

	.ds-overline {
		margin-bottom: var(--space-2);
	}

	h2 {
		font-family: var(--font-display);
		font-size: var(--text-h2);
		font-weight: var(--weight-bold);
		line-height: var(--leading-snug);
		margin: 0 0 var(--space-2);
		overflow-wrap: anywhere;
	}

	h2 a {
		color: var(--text);
		text-decoration: none;
	}

	.post-row:hover h2 a,
	.post-row:focus-within h2 a {
		color: var(--accent);
		text-decoration: underline;
	}

	p {
		color: var(--text-secondary);
		font-size: var(--text-body);
		line-height: var(--leading-normal);
		margin: 0 0 var(--space-3);
		max-width: 640px;
	}

	.post-tags {
		display: flex;
		flex-wrap: wrap;
		gap: var(--space-2);
	}

	.series {
		align-items: center;
		background: var(--accent-wash);
		border: 1px solid var(--border-accent);
		border-radius: var(--radius-sm);
		color: var(--accent);
		display: inline-flex;
		font-family: var(--font-mono);
		font-size: var(--text-xs);
		font-weight: var(--weight-medium);
		letter-spacing: var(--tracking-wider);
		min-height: 24px;
		padding: 0 var(--space-2);
		text-transform: uppercase;
	}

	@media (max-width: 560px) {
		.post-row {
			grid-template-columns: 36px minmax(0, 1fr);
		}
	}
</style>
