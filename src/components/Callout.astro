---
interface Props {
	tone?: 'note' | 'tip' | 'warning' | 'danger';
	title?: string;
}

const { tone = 'note', title } = Astro.props;
const labels = {
	note: '// note',
	tip: '>> tip',
	warning: '!! warning',
	danger: '!! danger',
};
---

<aside class:list={['callout', `callout-${tone}`]}>
	<strong>{title ?? labels[tone]}</strong>
	<div>
		<slot />
	</div>
</aside>

<style>
	.callout {
		background: var(--surface);
		border: 1px solid var(--border);
		border-left: 2px solid var(--callout-accent);
		border-radius: var(--radius-sm);
		color: var(--text-secondary);
		display: grid;
		gap: var(--space-2);
		margin: var(--space-6) 0;
		padding: var(--space-4) var(--space-5);
	}

	.callout-note {
		--callout-accent: var(--blue);
	}

	.callout-tip {
		--callout-accent: var(--green);
	}

	.callout-warning {
		--callout-accent: var(--amber);
	}

	.callout-danger {
		--callout-accent: var(--red);
	}

	strong {
		color: var(--callout-accent);
		font-family: var(--font-mono);
		font-size: var(--text-xs);
		letter-spacing: var(--tracking-wider);
		text-transform: uppercase;
	}

	:global(.callout p) {
		margin: 0;
	}
</style>
