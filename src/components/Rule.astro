---
interface Props {
	label?: string;
	variant?: 'solid' | 'ascii';
}

const { label, variant = 'solid' } = Astro.props;
---

<div class:list={['rule', `rule-${variant}`]} aria-hidden={!label}>
	{label && <span>{label}</span>}
</div>

<style>
	.rule {
		align-items: center;
		color: var(--text-muted);
		display: flex;
		font-family: var(--font-mono);
		font-size: var(--text-xs);
		font-weight: var(--weight-medium);
		letter-spacing: var(--tracking-wider);
		text-transform: uppercase;
		width: 100%;
	}

	.rule::after {
		border-top: 1px solid var(--border);
		content: '';
		flex: 1;
		margin-left: var(--space-3);
	}

	.rule-ascii {
		display: block;
		letter-spacing: 0;
		overflow: hidden;
		white-space: nowrap;
	}

	.rule-ascii::before {
		content: '/* ---------------------------------------------------------------- */';
	}

	.rule-ascii::after {
		display: none;
	}
</style>
